# =========================
# IdiomaConnect — env vars
# Copy to .env.local and fill in
# =========================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...        # server-only, NEVER expose
SUPABASE_PROJECT_REF=YOUR-PROJECT

# --- LLM / Audio (Groq) ---
GROQ_API_KEY=gsk_...

# --- TTS (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- Payments (Lemon Squeezy — Merchant of Record, works from Chile) ---
LEMONSQUEEZY_API_KEY=eyJhbGciOi...           # API Key from LS dashboard
LEMONSQUEEZY_STORE_ID=12345                  # numeric, from your store URL
LEMONSQUEEZY_WEBHOOK_SECRET=lswebhook_...    # signing secret from Webhooks page
NEXT_PUBLIC_LS_VARIANT_MONTHLY=67890         # variant_id for Monthly $9.99
NEXT_PUBLIC_LS_VARIANT_YEARLY=67891          # variant_id for Yearly $79

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hola@idiomaconnect.app

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
PARENT_DASHBOARD_PASSWORD=cambiar-en-prod

# --- Cron secret (manual trigger of /api/cron/* outside Vercel) ---
CRON_SECRET=genera-un-string-aleatorio-largo

# --- Observability (opcional pero recomendado) ---
# Crea proyecto Next.js en https://sentry.io y pega ambos DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
